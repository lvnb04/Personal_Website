---
// src/components/Footer.astro
// Site-wide bottom row: socials · centered quip · RSS — borderless, over the
// starfield (no bar). Stays in normal flow so the sticky-footer setup in Base
// pins it to the viewport bottom on short pages and to content-end on long ones.
// The quip is a constant (config), never randomized (CLAUDE.md §9 anti-pattern).
import { site } from "@config/site";
import Socials from "@components/Socials.astro";
---

<footer class="site-footer">
  <div class="bar container">
    <div class="end left"><Socials size={20} /></div>
    <span class="quip mono">
      <svg class="footer-icon" viewBox="0 0 28 28" width="20" height="20" fill="none" xmlns="http://www.w3.org/2000/svg" aria-hidden="true">
        <circle cx="14" cy="14" r="9"
          stroke="currentColor" stroke-width="2.6" stroke-linecap="round"
          fill="none"
          transform="rotate(-15 14 14)"
          stroke-dasharray="47.1 9.4"
          stroke-dashoffset="0"
        />
        <circle cx="14" cy="14" r="1.8" fill="currentColor" />
        <circle cx="20.4" cy="7.6" r="2.4" fill="#e0a14e" />
      </svg>
      {site.footerQuip}
    </span>
    <div class="end right">
      <a class="rss mono" href="/rss.xml" aria-label="RSS feed">rss</a>
    </div>
  </div>
</footer>

<style>
  .site-footer {
    position: relative;
    z-index: 1;
  }
  /* Three-column row: socials | centered quip | rss. Equal end columns keep the
     quip optically centered regardless of how wide the ends are.
     Override .container's 64rem cap so the row spans the full viewport and the
     ends sit at the screen extremes — aligned to the frame corners (--edge-pad). */
  .bar {
    max-width: none;
    display: grid;
    grid-template-columns: 1fr auto 1fr;
    align-items: center;
    gap: 1rem;
    min-height: 2.75rem;
    padding-block: 1rem;
    padding-inline: var(--edge-pad);
    font-size: 0.9rem;
  }
  .end {
    display: flex;
    align-items: center;
  }
  /* socials hard-left, rss hard-right (flank the centered quip) */
  .end.left {
    justify-content: flex-start;
  }
  .end.right {
    justify-content: flex-end;
  }
  .quip {
    color: var(--text-dim);
    text-align: center;
    display: inline-flex;
    align-items: center;
    gap: 0.5em;
  }
  .footer-icon {
    color: var(--text-dim);
    flex-shrink: 0;
    /* Optical baseline alignment */
    position: relative;
    top: -0.05em;
  }
  .rss {
    color: var(--text-faint);
    font-size: 0.9rem;
  }
  .rss:hover {
    color: var(--accent);
  }

  /* ── Mobile (≤767px): stack centered + symmetric (§5) ──────────────────────────
     The 3-column row crams on a phone (quip wraps awkwardly, ends asymmetric). Stack
     into three centered rows: socials · quip · rss. Borderless, in normal flow. */
  @media (max-width: 767px) {
    .bar {
      grid-template-columns: 1fr;   /* single centered column */
      justify-items: center;
      gap: 0.7rem;
      padding-block: 1.5rem;
      text-align: center;
    }
    .end.left,
    .end.right {
      justify-content: center;
    }
    .quip {
      /* keep the quip on one line if it fits; allow a clean centered wrap if not */
      white-space: nowrap;
    }
  }
  @media (max-width: 22rem) {
    .quip {
      white-space: normal;   /* very narrow: let it wrap centered rather than clip */
    }
  }

</style>
