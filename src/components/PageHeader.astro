---
// src/components/PageHeader.astro
// Centered title block for inner section pages (projects / papers / blog index).
// Just the title — no eyebrow, no lead (§D1). Iris serif: the accent carries the
// page identity, matching the About title and the overall page vibe.
interface Props {
  title: string;
}
const { title } = Astro.props;
---

<header class="page-header">
  <h1 class="ph-title">{title}</h1>
</header>

<style>
  .page-header {
    display: flex;
    justify-content: center;
    text-align: center;
    margin-bottom: 2rem;
  }
  .ph-title {
    font-family: var(--font-display);
    font-optical-sizing: auto;
    font-weight: 500;
    letter-spacing: -0.01em;
    /* iris title — brighter accent for clear visibility (accent owns page identity) */
    color: var(--accent-bright);
    font-size: clamp(1.6rem, 4vw, 2.25rem);
    margin: 0;
  }
</style>
