---
// src/components/Term.astro — inline definition popover for MDX posts (CLAUDE.md §11).
// Dotted-underline term + ⓘ; hover/focus (desktop) or tap-toggle (mobile) reveals a small
// definition card. Keyboard-focusable; viewport-aware (clamps so it never overflows).
// Usage in MDX:  <Term def="Pulse Code Modulation: raw, uncompressed audio samples.">PCM</Term>
interface Props {
  def: string;
}
const { def } = Astro.props;
---

<span class="term" tabindex="0" role="button" aria-expanded="false" data-term>
  <span class="term-word"><slot /></span><span class="term-mark" aria-hidden="true">&#9432;</span>
  <span class="term-pop" role="tooltip">{def}</span>
</span>

<style>
  .term {
    position: relative;
    cursor: help;
    white-space: nowrap;
  }
  .term-word {
    border-bottom: 1px dotted var(--accent);
    white-space: normal;
  }
  .term-mark {
    font-size: 0.7em;
    color: var(--accent);
    margin-left: 0.1em;
    vertical-align: super;
  }
  .term-pop {
    position: absolute;
    /* centered below the word: start at left:50% then shift left by half its own width */
    left: 50%;
    top: calc(100% + 0.6rem);
    transform: translateX(-50%) translateY(-3px);
    z-index: 60;
    width: max-content;
    max-width: min(18rem, 80vw);
    padding: 0.55rem 0.8rem;
    background: rgba(5, 7, 11, 0.96);
    border: 1px solid var(--border-bright);
    border-radius: var(--r-sm);
    box-shadow: 0 10px 30px rgba(0, 0, 0, 0.7);
    color: var(--text-dim);
    font-family: var(--font-mono);
    font-size: 0.78rem;
    line-height: 1.55;
    letter-spacing: 0.01em;
    white-space: normal;
    opacity: 0;
    visibility: hidden;
    transition: opacity 0.12s ease, transform 0.12s ease, visibility 0.12s;
  }
  /* desktop: hover/focus reveals; all: [data-open] reveals (tap) */
  @media (hover: hover) {
    .term:hover .term-pop,
    .term:focus-visible .term-pop {
      opacity: 1;
      visibility: visible;
      transform: translateX(-50%) translateY(0);
    }
  }
  .term[data-open] .term-pop {
    opacity: 1;
    visibility: visible;
    transform: translateX(-50%) translateY(0);
  }
</style>

<script>
  const hasHover = window.matchMedia("(hover: hover)").matches;

  document.querySelectorAll<HTMLElement>("[data-term]").forEach((term) => {
    const pop = term.querySelector<HTMLElement>(".term-pop")!;

    // Clamp: keep centered below the word but nudge if it would overflow the viewport.
    const clamp = () => {
      // Reset to CSS default (50% centering) then measure
      pop.style.left = "";
      pop.style.transform = "";
      const rect = pop.getBoundingClientRect();
      const margin = 8;
      let nudge = 0;
      if (rect.right > window.innerWidth - margin) {
        nudge = window.innerWidth - margin - rect.right;
      } else if (rect.left < margin) {
        nudge = margin - rect.left;
      }
      // apply nudge as additional translateX on top of the -50% centering
      if (nudge !== 0) {
        pop.style.transform = `translateX(calc(-50% + ${nudge}px)) translateY(0)`;
      }
    };

    const open = () => {
      term.setAttribute("data-open", "");
      term.setAttribute("aria-expanded", "true");
      clamp();
    };
    const close = () => {
      term.removeAttribute("data-open");
      term.setAttribute("aria-expanded", "false");
    };

    if (hasHover) {
      term.addEventListener("mouseenter", clamp);
      term.addEventListener("focus", () => {
        clamp();
        open();
      });
      term.addEventListener("blur", close);
    }

    // Tap / click / keyboard toggle (primary path on touch devices).
    term.addEventListener("click", (e) => {
      e.stopPropagation();
      term.hasAttribute("data-open") ? close() : open();
    });
    term.addEventListener("keydown", (e) => {
      if (e.key === "Enter" || e.key === " ") {
        e.preventDefault();
        term.hasAttribute("data-open") ? close() : open();
      } else if (e.key === "Escape") {
        close();
        term.blur();
      }
    });

    // Tap elsewhere closes it.
    document.addEventListener("click", (e) => {
      if (!term.contains(e.target as Node)) close();
    });
  });
</script>
