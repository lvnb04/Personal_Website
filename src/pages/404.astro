---
// src/pages/404.astro — out-of-distribution misclassification (CLAUDE.md §8).
// A wrong model is UNSURE: near-uniform, high-entropy probabilities; prediction rejected.
import Base from "@layouts/Base.astro";

// Near-uniform (high entropy) — never confidently wrong.
const dist = [
  { label: "/about", p: 0.31 },
  { label: "/projects", p: 0.28 },
  { label: "/blog", p: 0.26 },
  { label: "/papers", p: 0.15 },
];
---

<Base title="404 — out of distribution" rawTitle={true} description="Page not found.">
  <section class="ood">
    <p class="code mono">404</p>
    <p class="headline mono">input is out of distribution</p>

    <ul class="dist" aria-label="model output probabilities">
      {
        dist.map((d) => (
          <li class="row">
            <span class="lbl mono">{d.label}</span>
            <span class="track" aria-hidden="true">
              <span class="fill" style={`width:${d.p * 100}%`} />
            </span>
            <span class="val mono">{d.p.toFixed(2)}</span>
          </li>
        ))
      }
    </ul>

    <p class="reject mono">max confidence below threshold — prediction rejected</p>
    <a class="home mono" href="/">← return to training data</a>
  </section>
</Base>

<style>
  .ood {
    max-width: 32rem;
    margin: 2rem auto;
  }
  .code {
    font-size: clamp(4rem, 18vw, 7rem);
    line-height: 1;
    color: var(--error);
    margin: 0;
    font-weight: 600;
  }
  .headline {
    color: var(--text);
    font-size: 1.05rem;
    margin: 0.5rem 0 2rem;
  }
  .dist {
    list-style: none;
    margin: 0 0 1.75rem;
    padding: 0;
    display: grid;
    gap: 0.6rem;
  }
  .row {
    display: grid;
    grid-template-columns: 7.5rem 1fr 2.5rem;
    align-items: center;
    gap: 0.75rem;
  }
  .lbl {
    color: var(--text-dim);
    font-size: 0.82rem;
  }
  .track {
    height: 6px;
    border-radius: 999px;
    background: var(--surface);
    border: 1px solid var(--border);
    overflow: hidden;
  }
  .fill {
    display: block;
    height: 100%;
    background: var(--text-faint);
    border-radius: 999px;
  }
  .val {
    color: var(--text-faint);
    font-size: 0.78rem;
    text-align: right;
  }
  .reject {
    color: var(--text-faint);
    font-size: 0.85rem;
    margin: 0 0 1.5rem;
  }
  .home {
    color: var(--accent);
    font-size: 0.9rem;
  }
  .home:hover {
    color: var(--hover);
  }
</style>
