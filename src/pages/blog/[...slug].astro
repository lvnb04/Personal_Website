---
// src/pages/blog/[...slug].astro — renders each blog post through the Post layout.
// Posts sorted newest-first; prev = older neighbour, next = newer neighbour.
// Global MDX components: add here to make available in every post with no per-post import.
import { getCollection, render } from "astro:content";
import Post from "@layouts/Post.astro";
import Term from "@components/Term.astro";
import Sidenote from "@components/Sidenote.astro";

export async function getStaticPaths() {
  const posts = (await getCollection("blog")).sort(
    (a, b) => b.data.date.valueOf() - a.data.date.valueOf(),
  );
  return posts.map((post, i) => ({
    params: { slug: post.slug },
    props: {
      post,
      older: posts[i + 1] ?? null,
      newer: posts[i - 1] ?? null,
    },
  }));
}

const { post, older, newer } = Astro.props;
const { Content, headings } = await render(post);
const d = post.data;

const toLink = (p: typeof older) =>
  p ? { slug: p.slug, title: p.data.title } : null;
---

<Post
  title={d.title}
  description={d.description}
  date={d.date}
  updated={d.updated}
  tags={d.tags}
  headings={headings}
  body={post.body}
  ogImage={d.thumbnail?.src}
  prev={toLink(older)}
  next={toLink(newer)}
>
  <Content components={{ Term, Sidenote }} />
</Post>
