---
// src/pages/blog/index.astro — blog tile grid, newest first.
// Tile extras: meta line (<month year> · ~N min · N.Nk tokens) + 2–3 tags.
// Tag filtering is deferred until there are >10 posts (CLAUDE.md §8).
import { getCollection } from "astro:content";
import Base from "@layouts/Base.astro";
import PageHeader from "@components/PageHeader.astro";
import Tile from "@components/Tile.astro";
import SubscribeForm from "@components/SubscribeForm.astro";
import { readingStats, monthYear } from "@lib/readingStats";

const posts = (await getCollection("blog")).sort(
  (a, b) => b.data.date.valueOf() - a.data.date.valueOf(),
);
---

<Base title="blog" description="Notes on ML systems and building.">
  <PageHeader title="Blog" />

  {
    posts.length === 0 ? (
      <p class="empty mono">No posts yet — first one is on the way.</p>
    ) : (
      <div class="tile-grid">
        {posts.map((post) => {
          const stats = readingStats(post.body);
          return (
            <Tile
              href={`/blog/${post.slug}`}
              title={post.data.title}
              image={post.data.thumbnail}
              imageAlt={`${post.data.title} thumbnail`}
            >
              <span class="meta mono">
                {monthYear(post.data.date)} · {stats.tokensK} tokens · entropy: {stats.entropy}
              </span>
              <span class="tags">
                {post.data.tags.slice(0, 3).map((t) => (
                  <span class="tag mono">{t}</span>
                ))}
              </span>
            </Tile>
          );
        })}
      </div>
    )
  }

  <div slot="before-footer" class="subscribe-wrap">
    <SubscribeForm />
  </div>
</Base>

<style>
  .empty {
    color: var(--text-faint);
  }
  .meta {
    display: block;
    color: var(--text-faint);
    font-size: 0.76rem;
  }
  .tags {
    display: flex;
    flex-wrap: wrap;
    gap: 0.4rem;
    margin-top: 0.55rem;
  }
  .tag {
    font-size: 0.68rem;
    color: var(--text-dim);
    border: 1px solid var(--border);
    border-radius: var(--r-sm);
    padding: 0.1rem 0.45rem;
  }
</style>
